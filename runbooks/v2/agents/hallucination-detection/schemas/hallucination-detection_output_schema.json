{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hallucination Detection Output",
  "type": "object",
  "properties": {
    "hallucination_detected": {
      "type": "boolean"
    },
    "evidence_supported": {
      "type": "boolean"
    },
    "support_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "unsupported_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_review_required": {
      "type": "boolean"
    },
    "reasoning": {
      "type": "string"
    }
  },
  "required": [
    "hallucination_detected",
    "evidence_supported",
    "support_score",
    "unsupported_claims",
    "human_review_required",
    "reasoning"
  ],
  "additionalProperties": false
}