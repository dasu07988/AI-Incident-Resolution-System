{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Severity Assessment Output",
  "description": "Structured output returned by the Enterprise Severity Assessment Agent.",
  "type": "object",
  "properties": {
    "severity": {
      "type": "string",
      "enum": [
        "Critical",
        "High",
        "Medium",
        "Low"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "P1",
        "P2",
        "P3",
        "P4"
      ]
    },
    "business_impact": {
      "type": "string",
      "enum": [
        "High",
        "Medium",
        "Low"
      ]
    },
    "sla_response_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "requires_human_approval": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": [
    "severity",
    "priority",
    "business_impact",
    "sla_response_minutes",
    "requires_human_approval",
    "confidence"
  ],
  "additionalProperties": false
}