{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Incident Classification Output",
  "description": "Structured output returned by the Incident Classification Agent.",
  "type": "object",
  "properties": {
    "incident_id": {
      "type": "string",
      "description": "Unique identifier of the incident."
    },
    "incident_type": {
      "type": "string",
      "enum": [
        "API",
        "Database",
        "Network",
        "Infrastructure",
        "Authentication",
        "Security",
        "Storage",
        "Cloud",
        "Email",
        "Payment",
        "Monitoring",
        "Application",
        "Configuration",
        "DNS",
        "Unknown"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason": {
      "type": "string"
    },
    "next_agent": {
      "type": "string",
      "const": "Severity Assessment Agent"
    }
  },
  "required": [
    "incident_id",
    "incident_type",
    "confidence",
    "reason",
    "next_agent"
  ],
  "additionalProperties": false
}